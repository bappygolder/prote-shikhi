{
  "expo": {
    "name": "PoraShikhi",
    "slug": "porashikhi",
    "scheme": "porashikhi",
    "version": "1.13.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
