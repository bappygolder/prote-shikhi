      "buildNumber": "3",
      "bundleIdentifier": "au.com.olab.porashikhi"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#20201f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 3,
      "package": "au.com.olab.porashikhi"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "lastUpdated": "Monday, 11 May 2026"
    }
